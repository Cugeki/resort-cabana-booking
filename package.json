{
  "name": "resort-map",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "concurrently \"npm run start-backend -- $npm_config_map $npm_config_bookings\" \"npm run start-frontend\"",
    "start-backend": "npx ts-node backend/src/server.ts",
    "start-frontend": "cd frontend && npm run dev",
    "test:backend": "npm --prefix backend test",
    "test:e2e": "playwright test",
    "test": "npm run test:backend && npm run test:e2e"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/minimist": "^1.2.5",
    "@types/node": "^25.5.0",
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "minimist": "^1.2.8"
  }
}
